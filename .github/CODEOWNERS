# CODEOWNERS — change authorization & separation of duties.
# RMF/SSDF evidence: CM-5 (access restrictions for change), AC-6 (least privilege),
# CM-3 (configuration change control), SSDF PS.1 / PW.2.
#
# Required reviews on these paths give the AO/ISSM/SCA a documented approval chain. Replace the
# placeholder teams with your real GitHub teams and require review from Code Owners in branch
# protection.

# Compliance content — must be reviewed by the security / RMF team (ISSM/ISSO/ISSE).
/compliance/                @morbidsteve
/policy/                    @morbidsteve
/.github/workflows/         @morbidsteve
/.github/dependabot.yml     @morbidsteve
/.github/CODEOWNERS         @morbidsteve

# Evidence engine — security engineering owns the scripts that build the BoE.
/scripts/                   @morbidsteve

# AO dashboard.
/site/                      @morbidsteve

# Application workload — the development team, with security engineering as secondary reviewer.
/sample-app/                @morbidsteve
/deploy/                    @morbidsteve

# Everything else.
*                           @morbidsteve
